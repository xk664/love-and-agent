# =============================================================================
# Yu AI Agent - Environment Variables Configuration
# Server: 106.53.178.125
# Copy this file to .env and fill in your values
# =============================================================================

# App Settings
APP_ENV=dev
DEBUG=true

# Server Configuration
SERVER_IP=106.53.178.125

# Database Configuration (MySQL)
DB_HOST=106.53.178.125
DB_PORT=13306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=love_and_agent

# PgVector Configuration (PostgreSQL)
PGVECTOR_HOST=106.53.178.125
PGVECTOR_PORT=5432
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=
PGVECTOR_DATABASE=yu_agent
PGVECTOR_COLLECTION=embeddings
PGVECTOR_DIMENSION=1536

# Redis Configuration
REDIS_HOST=106.53.178.125
REDIS_PORT=16379
REDIS_DB=0
REDIS_PASSWORD=

# DashScope API (Alibaba Cloud)
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_MODEL=qwen-turbo
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2

# OpenAI API (Optional)
OPENAI_API_KEY=your_openai_api_key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4

# Internal Authentication
AUTH_INTERNAL_TOKEN=your_secure_internal_token
AUTH_TOKEN_EXPIRE_MINUTES=60

# RAG Settings
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
